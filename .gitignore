# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Stack: pnpm workspaces + Turborepo. App: apps/docs (TanStack Start, Vite, Nitro).
# Libraries: Rslib builds → dist/.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# local env files
.env
.env.*
.env.*.local
*.local

# testing
coverage

# turbo
.turbo

# vercel
.vercel

# build outputs
.next/
out/
build
dist
dist-ssr
.swc/
tsconfig.tsbuildinfo
*.tsbuildinfo

# TanStack Start / Nitro / Vite SSR (apps/docs)
.nitro
.tanstack
.wrangler
.output
.vinxi
.content-collections

# Vite (config reload temp files, some versions)
vite.config.*.timestamp-*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
.DS_Store
*.pem
count.txt
todos.json

# IDEs — JetBrains machine/user state (share via docs or .editorconfig instead)
.idea/

# storybook
storybook-static
build-storybook.log

# codecov
codecov
codecov.*

# scripts
.exports-analysis

# python cache
__pycache__/
*.py[cod]
