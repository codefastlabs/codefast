{
  "name": "@codefast/benchmark-viewer",
  "version": "0.3.16-canary.2",
  "private": true,
  "description": "React SSR benchmark history viewer server for Codefast benchmark packages",
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/benchmark-viewer"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./app/components/app": {
      "import": "./dist/app/components/app.mjs"
    },
    "./app/components/chart": {
      "import": "./dist/app/components/chart.mjs"
    },
    "./app/components/controls": {
      "import": "./dist/app/components/controls.mjs"
    },
    "./app/components/finder": {
      "import": "./dist/app/components/finder.mjs"
    },
    "./app/components/footer": {
      "import": "./dist/app/components/footer.mjs"
    },
    "./app/components/header": {
      "import": "./dist/app/components/header.mjs"
    },
    "./app/components/icons": {
      "import": "./dist/app/components/icons.mjs"
    },
    "./app/components/kpi": {
      "import": "./dist/app/components/kpi.mjs"
    },
    "./app/components/kpi-card": {
      "import": "./dist/app/components/kpi-card.mjs"
    },
    "./app/components/metrics": {
      "import": "./dist/app/components/metrics.mjs"
    },
    "./app/components/palette": {
      "import": "./dist/app/components/palette.mjs"
    },
    "./app/components/skip-to-chart": {
      "import": "./dist/app/components/skip-to-chart.mjs"
    },
    "./app/components/snapshot": {
      "import": "./dist/app/components/snapshot.mjs"
    },
    "./app/entry": {
      "types": "./dist/app/entry.d.ts",
      "import": "./dist/app/entry.js"
    },
    "./app/hooks/use-command-palette": {
      "import": "./dist/app/hooks/use-command-palette.mjs"
    },
    "./app/hooks/use-derived-payload": {
      "import": "./dist/app/hooks/use-derived-payload.mjs"
    },
    "./app/hooks/use-details-persist": {
      "import": "./dist/app/hooks/use-details-persist.mjs"
    },
    "./app/hooks/use-hash": {
      "import": "./dist/app/hooks/use-hash.mjs"
    },
    "./app/hooks/use-payload": {
      "import": "./dist/app/hooks/use-payload.mjs"
    },
    "./app/hooks/use-toast": {
      "import": "./dist/app/hooks/use-toast.mjs"
    },
    "./app/hooks/use-view": {
      "import": "./dist/app/hooks/use-view.mjs"
    },
    "./app/lib/chart-view": {
      "import": "./dist/app/lib/chart-view.mjs"
    },
    "./app/lib/colors": {
      "import": "./dist/app/lib/colors.mjs"
    },
    "./app/lib/constants": {
      "import": "./dist/app/lib/constants.mjs"
    },
    "./app/lib/format": {
      "import": "./dist/app/lib/format.mjs"
    },
    "./app/lib/hash": {
      "import": "./dist/app/lib/hash.mjs"
    },
    "./app/lib/metrics": {
      "import": "./dist/app/lib/metrics.mjs"
    },
    "./app/lib/skip-chart": {
      "import": "./dist/app/lib/skip-chart.mjs"
    },
    "./app/lib/utils": {
      "import": "./dist/app/lib/utils.mjs"
    },
    "./app/styles.css": "./dist/app/styles.css",
    "./constants": {
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.mts",
      "import": "./dist/server/index.mjs"
    },
    "./server/http": {
      "types": "./dist/server/http.d.mts",
      "import": "./dist/server/http.mjs"
    },
    "./server/payload": {
      "types": "./dist/server/payload.d.mts",
      "import": "./dist/server/payload.mjs"
    },
    "./server/port": {
      "types": "./dist/server/port.d.mts",
      "import": "./dist/server/port.mjs"
    },
    "./server/render": {
      "types": "./dist/server/render.d.mts",
      "import": "./dist/server/render.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "postbuild": "cp -r public dist/public",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codefast/benchmark-harness": "workspace:*",
    "@codefast/tailwind-variants": "workspace:*",
    "@hono/node-server": "catalog:",
    "chart.js": "catalog:",
    "chartjs-plugin-zoom": "catalog:",
    "hono": "catalog:",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "postcss-import": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
