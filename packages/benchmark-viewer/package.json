{
  "name": "@codefast/benchmark-viewer",
  "version": "1.0.0-canary.7",
  "private": true,
  "description": "React SSR benchmark history viewer server for Codefast benchmark packages",
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/benchmark-viewer"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": {
      "source": [
        "./src/*",
        "./src/*.ts",
        "./src/*.tsx",
        "./src/*/index.ts",
        "./src/*/index.tsx"
      ],
      "types": [
        "./dist/*.d.ts",
        "./dist/*/index.d.ts"
      ],
      "default": [
        "./dist/*.js",
        "./dist/*/index.js"
      ]
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants": {
      "source": "./src/constants.ts",
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./server": {
      "source": "./src/server/index.ts",
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./server/http": {
      "source": "./src/server/http.ts",
      "types": "./dist/server/http.d.ts",
      "import": "./dist/server/http.js"
    },
    "./server/payload": {
      "source": "./src/server/payload.ts",
      "types": "./dist/server/payload.d.ts",
      "import": "./dist/server/payload.js"
    },
    "./server/port": {
      "source": "./src/server/port.ts",
      "types": "./dist/server/port.d.ts",
      "import": "./dist/server/port.js"
    },
    "./server/render": {
      "source": "./src/server/render.tsx",
      "types": "./dist/server/render.d.ts",
      "import": "./dist/server/render.js"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && vite build && cp -r public dist/public",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@codefast/benchmark-harness": "workspace:*",
    "@codefast/tailwind-variants": "workspace:*",
    "@hono/node-server": "catalog:",
    "chart.js": "catalog:",
    "chartjs-plugin-zoom": "catalog:",
    "hono": "catalog:",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "postcss-import": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
