{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"]
  },
  // Compile the whole src tree: the server SSR-imports app components (`#/app/...`),
  // so they must emit as per-file dist modules for Node. Vite then overwrites
  // dist/app/entry.js with the bundled browser build (+ chunks + styles.css).
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", ".turbo", "coverage", "src/**/*.test.ts", "src/**/*.test.tsx", "tests"]
}
