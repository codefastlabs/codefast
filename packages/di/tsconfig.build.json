{
  "extends": ["./tsconfig.json", "@codefast/typescript-config/build-base.json"],
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "target": "ESNext"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.integration.test.ts", "src/**/*.spec.ts", "dist", "node_modules"]
}
