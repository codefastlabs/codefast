{
  "name": "@codefast/di",
  "version": "1.0.0-canary.7",
  "description": "Lightweight dependency injection primitives for Codefast",
  "keywords": [
    "codefast",
    "dependency-injection",
    "di",
    "inversion-of-control",
    "typescript"
  ],
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/di"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": {
      "source": [
        "./src/*",
        "./src/*.ts",
        "./src/*.tsx",
        "./src/*/index.ts",
        "./src/*/index.tsx"
      ],
      "types": [
        "./dist/*.d.ts",
        "./dist/*/index.d.ts"
      ],
      "default": [
        "./dist/*.js",
        "./dist/*/index.js"
      ]
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./binding": {
      "source": "./src/binding.ts",
      "types": "./dist/binding.d.ts",
      "import": "./dist/binding.js"
    },
    "./binding-scope": {
      "source": "./src/binding-scope.ts",
      "types": "./dist/binding-scope.d.ts",
      "import": "./dist/binding-scope.js"
    },
    "./binding-select": {
      "source": "./src/binding-select.ts",
      "types": "./dist/binding-select.d.ts",
      "import": "./dist/binding-select.js"
    },
    "./constraints": {
      "source": "./src/constraints.ts",
      "types": "./dist/constraints.d.ts",
      "import": "./dist/constraints.js"
    },
    "./constructor-type": {
      "source": "./src/constructor-type.ts",
      "types": "./dist/constructor-type.d.ts",
      "import": "./dist/constructor-type.js"
    },
    "./container": {
      "source": "./src/container.ts",
      "types": "./dist/container.d.ts",
      "import": "./dist/container.js"
    },
    "./decorators/inject": {
      "source": "./src/decorators/inject.ts",
      "types": "./dist/decorators/inject.d.ts",
      "import": "./dist/decorators/inject.js"
    },
    "./decorators/injectable": {
      "source": "./src/decorators/injectable.ts",
      "types": "./dist/decorators/injectable.d.ts",
      "import": "./dist/decorators/injectable.js"
    },
    "./decorators/lifecycle-decorators": {
      "source": "./src/decorators/lifecycle-decorators.ts",
      "types": "./dist/decorators/lifecycle-decorators.d.ts",
      "import": "./dist/decorators/lifecycle-decorators.js"
    },
    "./dependency-graph": {
      "source": "./src/dependency-graph.ts",
      "types": "./dist/dependency-graph.d.ts",
      "import": "./dist/dependency-graph.js"
    },
    "./environment": {
      "source": "./src/environment.ts",
      "types": "./dist/environment.d.ts",
      "import": "./dist/environment.js"
    },
    "./errors": {
      "source": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./graph-adapters/cytoscape": {
      "source": "./src/graph-adapters/cytoscape.ts",
      "types": "./dist/graph-adapters/cytoscape.d.ts",
      "import": "./dist/graph-adapters/cytoscape.js"
    },
    "./graph-adapters/dot": {
      "source": "./src/graph-adapters/dot.ts",
      "types": "./dist/graph-adapters/dot.d.ts",
      "import": "./dist/graph-adapters/dot.js"
    },
    "./graph-adapters/reactflow": {
      "source": "./src/graph-adapters/reactflow.ts",
      "types": "./dist/graph-adapters/reactflow.d.ts",
      "import": "./dist/graph-adapters/reactflow.js"
    },
    "./inspector": {
      "source": "./src/inspector.ts",
      "types": "./dist/inspector.d.ts",
      "import": "./dist/inspector.js"
    },
    "./lifecycle": {
      "source": "./src/lifecycle.ts",
      "types": "./dist/lifecycle.d.ts",
      "import": "./dist/lifecycle.js"
    },
    "./metadata/metadata-keys": {
      "source": "./src/metadata/metadata-keys.ts",
      "types": "./dist/metadata/metadata-keys.d.ts",
      "import": "./dist/metadata/metadata-keys.js"
    },
    "./metadata/metadata-reader-token": {
      "source": "./src/metadata/metadata-reader-token.ts",
      "types": "./dist/metadata/metadata-reader-token.d.ts",
      "import": "./dist/metadata/metadata-reader-token.js"
    },
    "./metadata/metadata-types": {
      "source": "./src/metadata/metadata-types.ts",
      "types": "./dist/metadata/metadata-types.d.ts",
      "import": "./dist/metadata/metadata-types.js"
    },
    "./metadata/symbol-metadata-reader": {
      "source": "./src/metadata/symbol-metadata-reader.ts",
      "types": "./dist/metadata/symbol-metadata-reader.d.ts",
      "import": "./dist/metadata/symbol-metadata-reader.js"
    },
    "./module": {
      "source": "./src/module.ts",
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    },
    "./registry": {
      "source": "./src/registry.ts",
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./resolve-options": {
      "source": "./src/resolve-options.ts",
      "types": "./dist/resolve-options.d.ts",
      "import": "./dist/resolve-options.js"
    },
    "./resolver": {
      "source": "./src/resolver.ts",
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./scope": {
      "source": "./src/scope.ts",
      "types": "./dist/scope.d.ts",
      "import": "./dist/scope.js"
    },
    "./token": {
      "source": "./src/token.ts",
      "types": "./dist/token.d.ts",
      "import": "./dist/token.js"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "examples": "for file in examples/*/*.ts; do echo \"=== Running $file ===\"; node --import tsx/esm \"$file\"; echo \"\n\" || exit 1; done",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/plugin-proposal-decorators": "catalog:",
    "@codefast/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "expect-type": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
