{
  "name": "@codefast/di",
  "version": "0.3.13-canary.3",
  "description": "Lightweight dependency injection primitives for Codefast",
  "keywords": [
    "codefast",
    "dependency-injection",
    "di",
    "inversion-of-control",
    "typescript"
  ],
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/di"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#lib/*": [
      "./dist/*.js",
      "./dist/*/index.js",
      "./dist/*",
      "./src/*",
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./binding": {
      "types": "./dist/binding.d.ts",
      "import": "./dist/binding.js"
    },
    "./binding-select": {
      "types": "./dist/binding-select.d.ts",
      "import": "./dist/binding-select.js"
    },
    "./constraints": {
      "types": "./dist/constraints.d.ts",
      "import": "./dist/constraints.js"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "import": "./dist/container.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "import": "./dist/decorators/index.js"
    },
    "./decorators/inject": {
      "types": "./dist/decorators/inject.d.ts",
      "import": "./dist/decorators/inject.js"
    },
    "./decorators/inject-optional": {
      "types": "./dist/decorators/inject-optional.d.ts",
      "import": "./dist/decorators/inject-optional.js"
    },
    "./decorators/injectable": {
      "types": "./dist/decorators/injectable.d.ts",
      "import": "./dist/decorators/injectable.js"
    },
    "./decorators/metadata": {
      "types": "./dist/decorators/metadata.d.ts",
      "import": "./dist/decorators/metadata.js"
    },
    "./decorators/param-registry": {
      "types": "./dist/decorators/param-registry.d.ts",
      "import": "./dist/decorators/param-registry.js"
    },
    "./decorators/reader": {
      "types": "./dist/decorators/reader.d.ts",
      "import": "./dist/decorators/reader.js"
    },
    "./dependency-graph": {
      "types": "./dist/dependency-graph.d.ts",
      "import": "./dist/dependency-graph.js"
    },
    "./environment": {
      "types": "./dist/environment.d.ts",
      "import": "./dist/environment.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./inspector": {
      "types": "./dist/inspector.d.ts",
      "import": "./dist/inspector.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./scope": {
      "types": "./dist/scope.d.ts",
      "import": "./dist/scope.js"
    },
    "./scope-validation": {
      "types": "./dist/scope-validation.d.ts",
      "import": "./dist/scope-validation.js"
    },
    "./token": {
      "types": "./dist/token.d.ts",
      "import": "./dist/token.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsgo -p tsconfig.build.json",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --reporter=dot",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
