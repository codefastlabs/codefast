{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.e2e.ts",
    "src/**/*.e2e.tsx",
    "src/**/*.story.ts",
    "src/**/*.story.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "dist",
    "node_modules"
  ]
}
