{
  "name": "@codefast/tailwind-variants",
  "version": "0.3.11",
  "description": "Tailwind CSS variants utilities with enhanced functionality and advanced type safety",
  "keywords": [
    "composition",
    "css",
    "monorepo",
    "styling",
    "tailwind",
    "tailwindcss",
    "type-safe",
    "typescript",
    "utilities",
    "variants"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/tailwind-variants#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/tailwind-variants"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ],
    "#test/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch --no-clean",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --coverage --ci",
    "test:watch": "jest --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "expect-type": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "ts-node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
