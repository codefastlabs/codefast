{
  "name": "@codefast/tailwind-variants",
  "version": "0.3.12",
  "description": "Tailwind CSS variants utilities with enhanced functionality and advanced type safety",
  "keywords": [
    "composition",
    "css",
    "monorepo",
    "styling",
    "tailwind",
    "tailwindcss",
    "type-safe",
    "typescript",
    "utilities",
    "variants"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/tailwind-variants#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/tailwind-variants"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch --no-clean",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --coverage --ci",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "expect-type": "^1.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
