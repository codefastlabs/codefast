{
  "name": "@codefast/tailwind-variants",
  "version": "1.0.0-canary.7",
  "description": "Tailwind CSS variants utilities with enhanced functionality and advanced type safety",
  "keywords": [
    "composition",
    "css",
    "monorepo",
    "styling",
    "tailwind",
    "tailwindcss",
    "type-safe",
    "typescript",
    "utilities",
    "variants"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/tailwind-variants#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/tailwind-variants"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": {
      "source": [
        "./src/*",
        "./src/*.ts",
        "./src/*.tsx",
        "./src/*/index.ts",
        "./src/*/index.tsx"
      ],
      "types": [
        "./dist/*.d.ts",
        "./dist/*/index.d.ts"
      ],
      "default": [
        "./dist/*.js",
        "./dist/*/index.js"
      ]
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "expect-type": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
