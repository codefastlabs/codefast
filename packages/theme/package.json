{
  "name": "@codefast/theme",
  "version": "0.3.13-canary.3",
  "description": "Theme management with React 19 features - optimistic updates, cross-tab sync, and SSR support",
  "keywords": [
    "dark-mode",
    "light-mode",
    "react",
    "react-19",
    "ssr",
    "theme",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/theme#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/tanstack-start/server": {
      "types": "./dist/adapters/tanstack-start/server.d.ts",
      "import": "./dist/adapters/tanstack-start/server.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./core/context": {
      "types": "./dist/core/context.d.ts",
      "import": "./dist/core/context.js"
    },
    "./core/provider": {
      "types": "./dist/core/provider.d.ts",
      "import": "./dist/core/provider.js"
    },
    "./core/use-theme": {
      "types": "./dist/core/use-theme.d.ts",
      "import": "./dist/core/use-theme.js"
    },
    "./script": {
      "types": "./dist/script/index.d.ts",
      "import": "./dist/script/index.js"
    },
    "./script/theme-script": {
      "types": "./dist/script/theme-script.d.ts",
      "import": "./dist/script/theme-script.js"
    },
    "./start": {
      "types": "./dist/start.d.ts",
      "import": "./dist/start.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils/dom": {
      "types": "./dist/utils/dom.d.ts",
      "import": "./dist/utils/dom.js"
    },
    "./utils/system": {
      "types": "./dist/utils/system.d.ts",
      "import": "./dist/utils/system.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsgo -p tsconfig.build.json",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --coverage --ci",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": "^1.0",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  }
}
