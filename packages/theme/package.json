{
  "name": "@codefast/theme",
  "version": "0.5.0-canary.0",
  "description": "Theme management with React 19 features - optimistic updates, cross-tab sync, and SSR support",
  "keywords": [
    "dark-mode",
    "light-mode",
    "react",
    "react-19",
    "ssr",
    "theme",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/theme#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./adapters/tanstack-start/server": {
      "source": "./src/adapters/tanstack-start/server.ts",
      "types": "./dist/adapters/tanstack-start/server.d.mts",
      "import": "./dist/adapters/tanstack-start/server.mjs"
    },
    "./constants": {
      "source": "./src/constants.ts",
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs"
    },
    "./core/context": {
      "source": "./src/core/context.tsx",
      "types": "./dist/core/context.d.mts",
      "import": "./dist/core/context.mjs"
    },
    "./core/provider": {
      "source": "./src/core/provider.tsx",
      "types": "./dist/core/provider.d.mts",
      "import": "./dist/core/provider.mjs"
    },
    "./core/use-theme": {
      "source": "./src/core/use-theme.ts",
      "types": "./dist/core/use-theme.d.mts",
      "import": "./dist/core/use-theme.mjs"
    },
    "./script/theme-script": {
      "source": "./src/script/theme-script.tsx",
      "types": "./dist/script/theme-script.d.mts",
      "import": "./dist/script/theme-script.mjs"
    },
    "./start": {
      "source": "./src/start.ts",
      "types": "./dist/start.d.mts",
      "import": "./dist/start.mjs"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    },
    "./utils/dom": {
      "source": "./src/utils/dom.ts",
      "types": "./dist/utils/dom.d.mts",
      "import": "./dist/utils/dom.mjs"
    },
    "./utils/system": {
      "source": "./src/utils/system.ts",
      "types": "./dist/utils/system.d.mts",
      "import": "./dist/utils/system.mjs"
    },
    "./vite": {
      "source": "./src/adapters/tanstack-start/vite.ts",
      "types": "./dist/adapters/tanstack-start/vite.d.mts",
      "import": "./dist/adapters/tanstack-start/vite.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@tanstack/react-start": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": ">=1.168.0",
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
