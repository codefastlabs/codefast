{
  "name": "@codefast/theme",
  "version": "1.0.0-canary.6",
  "description": "Appearance management for React 19 with HIG-inspired vocabulary - optimistic updates, cross-tab sync, and FOUC-free SSR",
  "keywords": [
    "dark-mode",
    "light-mode",
    "react",
    "react-19",
    "ssr",
    "theme",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/theme#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./appearance": {
      "source": "./src/appearance.ts",
      "types": "./dist/appearance.d.mts",
      "import": "./dist/appearance.mjs"
    },
    "./appearance-context": {
      "source": "./src/appearance-context.ts",
      "types": "./dist/appearance-context.d.mts",
      "import": "./dist/appearance-context.mjs"
    },
    "./appearance-provider": {
      "source": "./src/appearance-provider.tsx",
      "types": "./dist/appearance-provider.d.mts",
      "import": "./dist/appearance-provider.mjs"
    },
    "./appearance-script": {
      "source": "./src/appearance-script.tsx",
      "types": "./dist/appearance-script.d.mts",
      "import": "./dist/appearance-script.mjs"
    },
    "./color-scheme": {
      "source": "./src/color-scheme.ts",
      "types": "./dist/color-scheme.d.mts",
      "import": "./dist/color-scheme.mjs"
    },
    "./constants": {
      "source": "./src/constants.ts",
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs"
    },
    "./dom": {
      "source": "./src/dom.ts",
      "types": "./dist/dom.d.mts",
      "import": "./dist/dom.mjs"
    },
    "./use-appearance": {
      "source": "./src/use-appearance.ts",
      "types": "./dist/use-appearance.d.mts",
      "import": "./dist/use-appearance.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
