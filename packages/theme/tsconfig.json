{
  "extends": "@codefast/typescript-config/react.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "types": ["node", "vitest/globals"],
    "verbatimModuleSyntax": true,
    "paths": {
      "#/tests/*": ["./tests/*"],
      "#/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", ".turbo", "coverage"]
}
