{
  "name": "@codefast/benchmark-harness",
  "version": "0.3.15",
  "private": true,
  "description": "Shared tinybench harness utilities (subprocess protocol, fingerprinting, two-way reports) for Codefast benchmark packages",
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/benchmark-harness"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./child/bench-options": "./src/child/bench-options.ts",
    "./child/bench-scenario": "./src/child/bench-scenario.ts",
    "./child/create-run-all-trials": "./src/child/create-run-all-trials.ts",
    "./child/fingerprint": "./src/child/fingerprint.ts",
    "./child/run-benchmark-child-main": "./src/child/run-benchmark-child-main.ts",
    "./child/run-sanity-checks": "./src/child/run-sanity-checks.ts",
    "./parent/resolve-bench-parent-exit-code": "./src/parent/resolve-bench-parent-exit-code.ts",
    "./parent/run-bench-subprocess": "./src/parent/run-bench-subprocess.ts",
    "./report/aggregate": "./src/report/aggregate.ts",
    "./report/format": "./src/report/format.ts",
    "./report/jsonl": "./src/report/jsonl.ts",
    "./report/quantiles": "./src/report/quantiles.ts",
    "./report/two-way": "./src/report/two-way.ts",
    "./report/write": "./src/report/write.ts",
    "./server/build-payload": "./src/server/build-payload.ts",
    "./server/create-bench-server": "./src/server/create-bench-server.ts",
    "./server/find-available-port": "./src/server/find-available-port.ts",
    "./server/read-runs": "./src/server/read-runs.ts",
    "./server/server-types": "./src/server/server-types.ts",
    "./server/start-bench-server": "./src/server/start-bench-server.ts",
    "./shared/config": "./src/shared/config.ts",
    "./shared/env-keys": "./src/shared/env-keys.ts",
    "./shared/protocol": "./src/shared/protocol.ts"
  },
  "scripts": {
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "tinybench": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
