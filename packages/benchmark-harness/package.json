{
  "name": "@codefast/benchmark-harness",
  "version": "0.3.16-canary.1",
  "private": true,
  "description": "Shared tinybench harness utilities (subprocess protocol, fingerprinting, two-way reports) for Codefast benchmark packages",
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/benchmark-harness"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./child/bench-options": {
      "types": "./dist/child/bench-options.d.mts",
      "import": "./dist/child/bench-options.mjs"
    },
    "./child/bench-scenario": {
      "types": "./dist/child/bench-scenario.d.mts",
      "import": "./dist/child/bench-scenario.mjs"
    },
    "./child/create-run-all-trials": {
      "types": "./dist/child/create-run-all-trials.d.mts",
      "import": "./dist/child/create-run-all-trials.mjs"
    },
    "./child/fingerprint": {
      "types": "./dist/child/fingerprint.d.mts",
      "import": "./dist/child/fingerprint.mjs"
    },
    "./child/run-benchmark-child-main": {
      "types": "./dist/child/run-benchmark-child-main.d.mts",
      "import": "./dist/child/run-benchmark-child-main.mjs"
    },
    "./child/run-sanity-checks": {
      "types": "./dist/child/run-sanity-checks.d.mts",
      "import": "./dist/child/run-sanity-checks.mjs"
    },
    "./parent/resolve-bench-parent-exit-code": {
      "types": "./dist/parent/resolve-bench-parent-exit-code.d.mts",
      "import": "./dist/parent/resolve-bench-parent-exit-code.mjs"
    },
    "./parent/run-bench-subprocess": {
      "types": "./dist/parent/run-bench-subprocess.d.mts",
      "import": "./dist/parent/run-bench-subprocess.mjs"
    },
    "./report/aggregate": {
      "types": "./dist/report/aggregate.d.mts",
      "import": "./dist/report/aggregate.mjs"
    },
    "./report/format": {
      "types": "./dist/report/format.d.mts",
      "import": "./dist/report/format.mjs"
    },
    "./report/jsonl": {
      "types": "./dist/report/jsonl.d.mts",
      "import": "./dist/report/jsonl.mjs"
    },
    "./report/quantiles": {
      "types": "./dist/report/quantiles.d.mts",
      "import": "./dist/report/quantiles.mjs"
    },
    "./report/two-way": {
      "types": "./dist/report/two-way.d.mts",
      "import": "./dist/report/two-way.mjs"
    },
    "./report/write": {
      "types": "./dist/report/write.d.mts",
      "import": "./dist/report/write.mjs"
    },
    "./server/build-payload": {
      "types": "./dist/server/build-payload.d.mts",
      "import": "./dist/server/build-payload.mjs"
    },
    "./server/client/components/app": {
      "types": "./dist/server/client/components/app.d.mts",
      "import": "./dist/server/client/components/app.mjs"
    },
    "./server/client/components/chart-panel": {
      "types": "./dist/server/client/components/chart-panel.d.mts",
      "import": "./dist/server/client/components/chart-panel.mjs"
    },
    "./server/client/entry-server": {
      "types": "./dist/server/client/entry-server.d.mts",
      "import": "./dist/server/client/entry-server.mjs"
    },
    "./server/client/lib/colors": {
      "types": "./dist/server/client/lib/colors.d.mts",
      "import": "./dist/server/client/lib/colors.mjs"
    },
    "./server/client/lib/format": {
      "types": "./dist/server/client/lib/format.d.mts",
      "import": "./dist/server/client/lib/format.mjs"
    },
    "./server/client/lib/metrics": {
      "types": "./dist/server/client/lib/metrics.d.mts",
      "import": "./dist/server/client/lib/metrics.mjs"
    },
    "./server/client/styles.css": "./dist/server/client/styles.css",
    "./server/create-bench-server": {
      "types": "./dist/server/create-bench-server.d.mts",
      "import": "./dist/server/create-bench-server.mjs"
    },
    "./server/find-available-port": {
      "types": "./dist/server/find-available-port.d.mts",
      "import": "./dist/server/find-available-port.mjs"
    },
    "./server/read-runs": {
      "types": "./dist/server/read-runs.d.mts",
      "import": "./dist/server/read-runs.mjs"
    },
    "./server/server-types": {
      "types": "./dist/server/server-types.d.mts",
      "import": "./dist/server/server-types.mjs"
    },
    "./server/start-bench-server": {
      "types": "./dist/server/start-bench-server.d.mts",
      "import": "./dist/server/start-bench-server.mjs"
    },
    "./shared/config": {
      "types": "./dist/shared/config.d.mts",
      "import": "./dist/shared/config.mjs"
    },
    "./shared/env-keys": {
      "types": "./dist/shared/env-keys.d.mts",
      "import": "./dist/shared/env-keys.mjs"
    },
    "./shared/protocol": {
      "types": "./dist/shared/protocol.d.mts",
      "import": "./dist/shared/protocol.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chart.js": "catalog:",
    "chartjs-plugin-zoom": "catalog:",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tinybench": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "postcss-import": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
