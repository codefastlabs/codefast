{
  "name": "@codefast/benchmark-harness",
  "version": "0.3.14",
  "private": true,
  "description": "Shared tinybench harness utilities (subprocess protocol, fingerprinting, two-way reports) for Codefast benchmark packages",
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/benchmark-harness"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./protocol": "./src/protocol.ts",
    "./fingerprint": "./src/child/fingerprint.ts",
    "./bench-options": "./src/child/bench-options.ts",
    "./bench-scenario": "./src/child/bench-scenario.ts",
    "./create-run-all-trials": "./src/child/create-run-all-trials.ts",
    "./run-sanity-checks": "./src/child/run-sanity-checks.ts",
    "./run-benchmark-child-main": "./src/child/run-benchmark-child-main.ts",
    "./resolve-bench-parent-exit-code": "./src/parent/resolve-bench-parent-exit-code.ts",
    "./report": "./src/report/index.ts",
    "./stats/quantiles": "./src/stats/quantiles.ts",
    "./presentation/format": "./src/presentation/format.ts",
    "./jsonl": "./src/report/jsonl.ts",
    "./subprocess": "./src/parent/run-bench-subprocess.ts"
  },
  "scripts": {
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "tinybench": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
