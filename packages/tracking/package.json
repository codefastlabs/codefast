{
  "name": "@codefast/tracking",
  "version": "1.0.0-canary.6",
  "description": "Consent-gated, type-safe event tracking for TanStack Start — client tracker and server consent helpers over a per-app Standard Schema event catalog",
  "keywords": [
    "analytics",
    "codefast",
    "consent",
    "standard-schema",
    "tanstack-start",
    "tracking",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/tracking#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/tracking"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./dist/client/index.d.mts",
      "import": "./dist/client/index.mjs"
    },
    "./destinations": {
      "source": "./src/destinations/index.ts",
      "types": "./dist/destinations/index.d.mts",
      "import": "./dist/destinations/index.mjs"
    },
    "./destinations/vercel-analytics": {
      "source": "./src/destinations/vercel-analytics.ts",
      "types": "./dist/destinations/vercel-analytics.d.mts",
      "import": "./dist/destinations/vercel-analytics.mjs"
    },
    "./import-protection": {
      "source": "./src/import-protection.ts",
      "types": "./dist/import-protection.d.mts",
      "import": "./dist/import-protection.mjs"
    },
    "./react": {
      "source": "./src/react/index.ts",
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./server": {
      "source": "./src/server/index.ts",
      "types": "./dist/server/index.d.mts",
      "import": "./dist/server/index.mjs"
    },
    "./tanstack-start": {
      "source": "./src/adapters/tanstack-start.ts",
      "types": "./dist/adapters/tanstack-start.d.mts",
      "import": "./dist/adapters/tanstack-start.mjs"
    },
    "./css/*": "./src/css/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:type": "vitest run tests/types",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@tanstack/react-start": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native": "catalog:",
    "@vercel/analytics": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "expect-type": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": ">=1.168.0",
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "@vercel/analytics": ">=1.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    },
    "@vercel/analytics": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
