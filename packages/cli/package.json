{
  "name": "@codefast/cli",
  "version": "0.3.13-canary.3",
  "description": "Developer CLI for the Codefast monorepo (mirror, arrange)",
  "keywords": [
    "cli",
    "codefast",
    "monorepo",
    "tailwind",
    "tailwindcss",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/cli"
  },
  "bin": {
    "codefast": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "imports": {
    "#*": [
      "./src/*"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "di:graph": "tsx scripts/visualize-di.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codefast/di": "workspace:*",
    "commander": "catalog:",
    "jiti": "catalog:",
    "picomatch": "catalog:",
    "typescript": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "unplugin-swc": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
