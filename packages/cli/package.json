{
  "name": "@codefast/cli",
  "version": "0.3.12-canary.1",
  "private": true,
  "description": "Developer CLI for the Codefast monorepo (mirror, arrange)",
  "keywords": [
    "cli",
    "codefast",
    "monorepo",
    "tailwind",
    "tailwindcss",
    "typescript"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "packages/cli"
  },
  "bin": {
    "codefast": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "imports": {
    "#*": [
      "./dist/*.js",
      "./dist/*/index.js",
      "./dist/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx",
      "./src/*"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "rm -rf dist && tsgo -p tsconfig.build.json",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --coverage --ci",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "commander": "catalog:",
    "picomatch": "catalog:",
    "typescript": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:",
    "@typescript/native-preview": "catalog:",
    "jest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
