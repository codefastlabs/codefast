{
  "extends": "@codefast/typescript-config/library.json",
  "compilerOptions": {
    "experimentalDecorators": false,
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx",
    "paths": {
      "#/tests/*": ["./tests/*"],
      "#/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
