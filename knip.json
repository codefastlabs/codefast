{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["package.json", "codefast.config.js"]
    },
    "apps/ui": {
      "entry": ["src/router.tsx"]
    },
    "packages/benchmark-harness": {
      "ignoreBinaries": ["tsx"]
    },
    "packages/benchmark-viewer": {
      "ignoreDependencies": ["babel-plugin-react-compiler"]
    },
    "packages/di": {
      "entry": ["examples/**/*.ts", "tests/integration/accessor-e2e.script.ts"],
      "ignoreDependencies": ["@babel/plugin-proposal-decorators"]
    }
  },
  "rules": {
    "optionalPeerDependencies": "off"
  }
}
