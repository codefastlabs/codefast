#-------------------------------------------------------------------------------
# Vercel upload — pnpm workspaces + Turborepo. App: apps/docs (Vite, TanStack
# Start, nitro/vite, @content-collections/vite). Packages: Rslib → dist/.
# Do not ignore .git (Turbo + install hooks need a real repository on the builder).
#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------
# Dependencies and package managers
#-------------------------------------------------------------------------------

node_modules
.pnpm-store

#-------------------------------------------------------------------------------
# Environment
#-------------------------------------------------------------------------------

.env
.env.*
.env.*.local
*.local
!.env.example

#-------------------------------------------------------------------------------
# Build outputs and tool caches (this stack only)
#-------------------------------------------------------------------------------

dist
.swc
.output
.tanstack
.content-collections
vite.config.*.timestamp-*

#-------------------------------------------------------------------------------
# Monorepo tooling
#-------------------------------------------------------------------------------

.turbo
.changeset

#-------------------------------------------------------------------------------
# Testing
#-------------------------------------------------------------------------------

coverage

#-------------------------------------------------------------------------------
# Logs and debug
#-------------------------------------------------------------------------------

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

#-------------------------------------------------------------------------------
# Editor, OS, local scratch
#-------------------------------------------------------------------------------

.idea
.DS_Store
Thumbs.db
*.pem
count.txt
todos.json
.exports-analysis

#-------------------------------------------------------------------------------
# Local Vercel CLI
#-------------------------------------------------------------------------------

.vercel
