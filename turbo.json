{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "//#lint": {
      "inputs": ["$TURBO_DEFAULT$", ".oxlintrc.json", ".editorconfig", ".gitignore"],
      "outputs": []
    },
    "//#lint:fix": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".oxlintrc.json", ".editorconfig", ".gitignore"],
      "outputs": []
    },
    "//#format": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".oxfmtrc.json", ".editorconfig", ".gitignore"],
      "outputs": []
    },
    "//#format:check": {
      "inputs": ["$TURBO_DEFAULT$", ".oxfmtrc.json", ".editorconfig", ".gitignore"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "tsconfig.*.json"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"]
    },
    "test:coverage": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:coverage:ci": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "bench": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "src/**/*.js", "src/**/*.ts"]
    }
  }
}
