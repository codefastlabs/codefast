{
  "$schema": "./node_modules/turbo/schema.json",
  "cacheMaxAge": "7d",
  "globalEnv": ["SKIP_INSTALL_SIMPLE_GIT_HOOKS"],
  "tasks": {
    "//#format": {
      "cache": false
    },
    "//#format:check": {},
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**", ".vercel/output/**"],
      "outputLogs": "new-only"
    },
    "check-types": {
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "tsconfig.*.json"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"]
    },
    "test:coverage": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"]
    },
    "test:integration": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"]
    },
    "test:type": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"]
    },
    "test:unit": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.setup.*"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "bench": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "tsconfig.*.json"],
      "passThroughEnv": ["BENCH_FAST", "BENCH_FULL", "BENCH_VERBOSE", "BENCH_TRIALS"]
    },
    "bench:serve": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["BENCH_PORT"]
    }
  }
}
