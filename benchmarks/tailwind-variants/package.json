{
  "name": "@codefast/benchmark-tailwind-variants",
  "version": "0.3.16-canary.3",
  "private": true,
  "description": "Subprocess tinybench harness: @codefast/tailwind-variants vs tailwind-variants and vs class-variance-authority (pairwise reports)",
  "keywords": [
    "benchmark",
    "css",
    "performance",
    "tailwind",
    "tailwindcss",
    "utilities",
    "variants"
  ],
  "homepage": "https://github.com/codefastlabs/codefast/tree/main/benchmarks/tailwind-variants#readme",
  "bugs": {
    "url": "https://github.com/codefastlabs/codefast/issues"
  },
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "benchmarks/tailwind-variants"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "bench": "node --import tsx/esm src/harness/run.ts",
    "bench:class-variance-authority": "node --import tsx/esm src/class-variance-authority-benches.ts",
    "bench:codefast": "node --import tsx/esm src/codefast-benches.ts",
    "bench:fast": "BENCH_FAST=1 node --import tsx/esm src/harness/run.ts",
    "bench:full": "BENCH_FULL=1 node --import tsx/esm src/harness/run.ts",
    "bench:tailwind-variants": "node --import tsx/esm src/tailwind-variants-benches.ts",
    "bench:serve": "node --import tsx/esm src/harness/serve.ts",
    "bench:verbose": "BENCH_VERBOSE=1 node --import tsx/esm src/harness/run.ts",
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "@codefast/benchmark-harness": "workspace:*",
    "@codefast/benchmark-viewer": "workspace:*",
    "@codefast/tailwind-variants": "workspace:*",
    "class-variance-authority": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tinybench": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
