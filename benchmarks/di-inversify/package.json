{
  "name": "@codefast/benchmark-di-inversify",
  "version": "0.0.1",
  "private": true,
  "description": "Head-to-head tinybench harness: InversifyJS v8 vs @codefast/di (same scenarios per library)",
  "keywords": [
    "benchmark",
    "codefast",
    "dependency-injection",
    "inversify"
  ],
  "license": "MIT",
  "author": "Vuong Phan <mr.thevuong@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codefastlabs/codefast.git",
    "directory": "benchmarks/di-inversify"
  },
  "type": "module",
  "scripts": {
    "check-types": "tsgo --noEmit -p tsconfig.codefast.json && tsgo --noEmit -p tsconfig.inversify.json",
    "bench": "tsx src/harness/run.ts",
    "bench:di": "tsx src/harness/run.ts",
    "bench:verbose": "BENCH_VERBOSE=1 tsx src/harness/run.ts",
    "bench:fast": "BENCH_FAST=1 tsx src/harness/run.ts",
    "bench:full": "BENCH_FULL=1 tsx src/harness/run.ts",
    "bench:codefast": "tsx --tsconfig tsconfig.codefast.json src/codefast-benches.ts",
    "bench:inversify": "tsx --tsconfig tsconfig.inversify.json src/inversify-benches.ts"
  },
  "dependencies": {
    "@codefast/di": "workspace:*",
    "inversify": "catalog:",
    "reflect-metadata": "catalog:",
    "tinybench": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@codefast/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
