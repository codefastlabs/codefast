{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@codefast/typescript-config/library.json",
  "compilerOptions": {
    "experimentalDecorators": false,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/codefast-benches.ts",
    "src/harness/**/*.ts",
    "src/scenarios/types.ts",
    "src/scenarios/collect-codefast-scenarios.ts",
    "src/scenarios/codefast/**/*.ts",
    "src/fixtures/realistic-graph.ts",
    "src/fixtures/codefast-adapter.ts"
  ]
}
