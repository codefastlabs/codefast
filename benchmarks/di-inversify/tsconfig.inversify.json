{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@codefast/typescript-config/library.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "types": ["node", "reflect-metadata"]
  },
  "include": [
    "src/inversify-benches.ts",
    "src/harness/**/*.ts",
    "src/scenarios/types.ts",
    "src/scenarios/inversify/**/*.ts",
    "src/fixtures/realistic-graph.ts",
    "src/fixtures/inversify-adapter.ts"
  ]
}
