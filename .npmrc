# Resolve workspace package specs from the registry unless they use the `workspace:`
# protocol. apps/start-demo declares `@codefast/*` with real npm version ranges so it
# consumes the PUBLISHED packages (their built `dist/`) like an external user, instead of
# being silently linked to the local `packages/*` sources. Existing packages keep using
# `workspace:*`, which always links regardless of this setting.
link-workspace-packages=false
