# Resolve workspace package specs from the registry unless they use the `workspace:`
# protocol. The examples/* apps reference `@codefast/*` via the catalog (which pins the
# PUBLISHED versions), so they consume the real npm artifacts (built `dist/`) like an
# external user instead of being silently linked to the local `packages/*` sources.
# Load-bearing: flipping this to `true` would silently link examples to local source.
# Docs apps (apps/*) and packages keep using `workspace:*`, which always links regardless.
link-workspace-packages=false
