{
  "name": "codefast",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "turbo run bench",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@codefast*/*...",
    "check": "pnpm run lint && pnpm run format:check",
    "check:fix": "pnpm run lint:fix && pnpm run format",
    "clean": "turbo clean && pnpm clean:cache && pnpm clean:modules",
    "clean:cache": "pnpm store prune",
    "clean:modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "deps:install": "pnpm install && pnpm build:packages",
    "deps:outdated": "pnpm outdated",
    "deps:reinstall": "pnpm clean && pnpm install && pnpm build:packages",
    "deps:update": "pnpm up --latest --recursive",
    "deps:update:interactive": "pnpm up --latest --recursive --interactive",
    "dev": "turbo run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate:exports": "scripts/generate-exports.py",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix --deny-warnings",
    "prepare": "simple-git-hooks",
    "release": "changeset",
    "release:canary:enter": "changeset pre enter canary",
    "release:canary:exit": "changeset pre exit",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:ci": "turbo run test:coverage:ci",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,jsx,mjs,cjs}": [
      "pnpm exec oxfmt",
      "pnpm exec oxlint --fix --deny-warnings"
    ],
    "*.{md,json,jsonc,css}": "pnpm exec oxfmt"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "h3": "^2.0.1-rc.20",
      "h3-v2": "npm:h3@^2.0.1-rc.20",
      "typescript": "^6.0.2"
    },
    "packageExtensions": {
      "@content-collections/core@*": {
        "peerDependencies": {
          "typescript": ">=5.0.2 <7.0.0"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@content-collections/vite>vite": "^8.0.0"
      }
    }
  }
}
