{
  "name": "codefast",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "bench": "pnpm --filter @codefast/benchmark-di-inversify bench",
    "build:packages": "turbo run build --filter=@codefast*/*...",
    "check": "turbo run lint format:check check-types",
    "check-types": "turbo run check-types",
    "check:fix": "turbo run lint:fix && turbo run format",
    "clean": "turbo clean",
    "clean:cache": "pnpm store prune",
    "clean:modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "cli:arrange-analyze": "pnpm exec codefast arrange analyze",
    "cli:arrange-apply": "pnpm exec codefast arrange apply",
    "cli:arrange-preview": "pnpm exec codefast arrange preview",
    "cli:mirror-sync": "pnpm exec codefast mirror sync",
    "deps:install": "pnpm install && pnpm build:packages",
    "deps:outdated": "pnpm outdated --recursive",
    "deps:reinstall": "pnpm clean && pnpm clean:modules && pnpm install && pnpm build:packages",
    "deps:update": "pnpm update --latest --recursive",
    "deps:update:interactive": "pnpm dlx taze@latest latest --recursive --interactive --write --install && pnpm build:packages",
    "dev": "turbo run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix --deny-warnings",
    "prepare": "simple-git-hooks",
    "release": "changeset",
    "release:canary:enter": "changeset pre enter canary",
    "release:canary:exit": "changeset pre exit",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "verify": "pnpm build:packages && turbo run lint:fix && turbo run format && turbo run check-types test:coverage"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@codefast/cli": "workspace:*",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "simple-git-hooks": "catalog:",
    "ts-node": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "sharp",
      "simple-git-hooks",
      "unrs-resolver"
    ]
  }
}
