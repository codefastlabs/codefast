{
  "name": "codefast",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "turbo run bench",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@codefast*/*...",
    "clean": "turbo clean && pnpm clean:cache && pnpm clean:modules",
    "clean:cache": "pnpm store prune",
    "clean:modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "deps:check": "pnpm outdated",
    "deps:install": "pnpm install && pnpm build:packages",
    "deps:reinstall": "pnpm clean && pnpm install && pnpm build:packages",
    "deps:update": "pnpm up --latest --recursive && pnpm deps:install",
    "deps:upgrade": "pnpm up --latest --recursive --interactive && pnpm deps:install",
    "dev": "turbo run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint --fix . --deny-warnings",
    "quality": "pnpm run lint && pnpm run format:check",
    "quality:fix": "pnpm run lint:fix && pnpm run format",
    "generate:exports": "scripts/generate-exports.py",
    "prepare": "simple-git-hooks",
    "release": "changeset",
    "release:canary:enter": "changeset pre enter canary",
    "release:canary:exit": "changeset pre exit",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:ci": "turbo run test:coverage:ci",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^25.3.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0-beta.12"
    }
  }
}
