{
  "name": "codefast",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "turbo run bench",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@codefast*/*...",
    "check-types": "turbo run check-types",
    "clean": "turbo clean",
    "clean:cache": "pnpm store prune && turbo clean",
    "clean:modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "clean:next": "pnpm -r exec rm -rf .next",
    "deploy:preview": "vercel deploy --archive=tgz",
    "deps:audit": "pnpm audit",
    "deps:audit:fix": "pnpm audit --fix",
    "deps:install": "pnpm install",
    "deps:licenses": "pnpm licenses list",
    "deps:outdated": "pnpm outdated --recursive",
    "deps:reinstall": "pnpm clean && pnpm deps:install && pnpm build:packages",
    "deps:upgrade": "pnpm up --latest --recursive --interactive",
    "dev": "pnpm clean:next && turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:exports": "tsx scripts/generate-exports.ts",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "precommit": "lint-staged",
    "prepare": "simple-git-hooks",
    "release": "changeset",
    "release:canary:enter": "changeset pre enter canary",
    "release:canary:exit": "changeset pre exit",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:ci": "turbo run test:coverage:ci",
    "test:watch": "turbo run test:watch"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@commitlint/types": "^20.2.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-packagejson": "^2.5.20",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.0-beta.0"
    }
  }
}
