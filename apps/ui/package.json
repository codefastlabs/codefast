    "test:coverage": "vitest run --coverage --project unit",
    "test:integration": "vitest run --project unit tests/integration",
    "test:type": "vitest run --project unit tests/types",
    "test:unit": "vitest run --project unit tests/unit",
    "test:watch": "vitest"
  },
