{
  "name": "@apps/ui",
  "private": true,
  "type": "module",
  "imports": {
    "#/tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx",
      "./tests/*/index.ts",
      "./tests/*/index.tsx"
    ],
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "generate:og": "node scripts/generate-og-image.ts",
    "preview": "vite preview",
    "check-types": "tsc --noEmit",
