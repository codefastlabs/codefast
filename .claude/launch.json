{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@apps/web", "exec", "vite", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@codefast/ui", "exec", "storybook", "dev", "-p", "6006", "--no-open"],
      "port": 6006
    }
  ]
}
